## Minimal runtime Dockerfile (microdnf-only, no torch, wrapper in site-packages)
## Simplified EPP Dockerfile - UDS tokenizer only (no vLLM, no embedded tokenizer)
## This build uses the default kv-cache pool (UDS-only, no embedded_tokenizers build tag)
## Tokenization is handled by a separate UDS tokenizer sidecar container
##
## CGO is still required for ZMQ (kvevents) but Python/vLLM dependencies are removed
# EPEL packages build from source stage
FROM registry.access.redhat.com/ubi9/ubi-minimal:9.7 AS epel-base

RUN microdnf install -y gcc-toolset-14 libtool make automake jq \
    zlib-devel sqlite-devel ncurses-devel bzip2-devel openssl-devel \
    tk-devel libpcap-devel xz-devel libffi-devel

# Build & Install Python2
RUN \
    curl -L https://www.python.org/ftp/python/2.7.2/Python-2.7.2.tgz | tar xvz && \
    cd Python-2.7.2 && \
    source /opt/rh/gcc-toolset-14/enable && \
    ./configure && make -j $(nproc) && make altinstall && \
    ln -sf /usr/local/bin/python2.7 /usr/bin/python

# zeromq-devel
RUN \
    ZMQ_LATEST_VERSION=$(curl -s "https://api.github.com/repos/zeromq/libzmq/releases/latest" | jq -r '.tag_name' | sed 's/v//') && \
    curl -L https://github.com/zeromq/libzmq/releases/download/v${ZMQ_LATEST_VERSION}/zeromq-${ZMQ_LATEST_VERSION}.tar.gz | tar xvz && \
    mv zeromq-${ZMQ_LATEST_VERSION} zeromq && cd zeromq && \
    source /opt/rh/gcc-toolset-14/enable && \
    ./autogen.sh && ./configure --prefix=/usr/ && make -j $(nproc) && \
    make install

# libsodium (zeromq transtitive dependency)
RUN \
    LIBSODIUM_LATEST_VERSION=$(curl -s "https://api.github.com/repos/jedisct1/libsodium/releases/latest" | jq -r '.tag_name' | sed 's/-RELEASE//') && \
    curl -L https://download.libsodium.org/libsodium/releases/libsodium-${LIBSODIUM_LATEST_VERSION}.tar.gz | tar xvz && \
    mv libsodium-${LIBSODIUM_LATEST_VERSION} libsodium && cd libsodium && \
    source /opt/rh/gcc-toolset-14/enable && \
    ./autogen.sh && ./configure --prefix=/usr/ && make -j $(nproc) && \
    make install

# libunwind (zeromq transtitive dependency)
RUN \
    LIBUNWIND_LATEST_VERSION=$(curl -s "https://api.github.com/repos/libunwind/libunwind/releases/latest" | jq -r '.tag_name' | sed 's/v//') && \
    curl -L https://github.com/libunwind/libunwind/releases/download/v${LIBUNWIND_LATEST_VERSION}/libunwind-${LIBUNWIND_LATEST_VERSION}.tar.gz | tar xvz && \
    mv libunwind-${LIBUNWIND_LATEST_VERSION} libunwind && cd libunwind && \
    source /opt/rh/gcc-toolset-14/enable && \
    ./configure --prefix=/usr/ && make -j $(nproc) && \
    make install

# openpgm (zeromq transtitive dependency)
RUN \
    # this is the latest version, no newer releases since 2012
    curl -L https://storage.googleapis.com/google-code-archive-downloads/v2/code.google.com/openpgm/libpgm-5.2.122.tar.gz | tar xvz && \
    mv libpgm-5.2.122 libpgm && cd libpgm/openpgm/pgm && \
    source /opt/rh/gcc-toolset-14/enable && \
    ./configure --prefix=/usr/ --build=powerpc64le-unknown-linux-gnu && make -j $(nproc) && \
    make install

# Go build stage
FROM registry.access.redhat.com/ubi9/go-toolset:1.25.7 AS go-builder

ARG TARGETOS
ARG TARGETARCH

USER root

WORKDIR /workspace

# Copy Red Hat repository configuration for zeromq packages
# COPY rhelai.repo /etc/yum.repos.d/rhelai.repo

# Install ZMQ development libraries (required for CGO)
RUN dnf install -y gcc-toolset-14 make pkgconfig && \
    dnf clean all
RUN --mount=type=cache,from=epel-base,source=/zeromq,target=/zeromq \
    --mount=type=cache,from=epel-base,source=/libsodium,target=/libsodium \
    --mount=type=cache,from=epel-base,source=/libunwind,target=/libunwind \
    --mount=type=cache,from=epel-base,source=/libpgm,target=/libpgm \
    source /opt/rh/gcc-toolset-14/enable && \
    make -C /zeromq install && \
    make -C /libsodium install && \
    make -C /libunwind install && \
    make -C /libpgm/openpgm/pgm install

# Copy the Go Modules manifests
COPY go.mod go.mod
COPY go.sum go.sum

# Copy the go source
COPY cmd/ cmd/
COPY pkg/ pkg/

RUN go mod download

# Build EPP with CGO for ZMQ only (no Python, no embedded tokenizer)
# The default kv-cache build uses UDS tokenizer (//go:build !embedded_tokenizers)
RUN CGO_ENABLED=1 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o bin/epp cmd/epp/main.go

# Runtime stage
# Use ubi9 as a minimal base image to package the manager binary
# Refer to https://catalog.redhat.com/software/containers/ubi9/ubi-minimal/615bd9b4075b022acc111bf5 for more details
FROM registry.access.redhat.com/ubi9/ubi-minimal:9.7

WORKDIR /

# Copy Red Hat repository configuration for zeromq packages
# COPY rhelai.repo /etc/yum.repos.d/rhelai.repo

# Install ZMQ runtime library only (no Python needed)
RUN microdnf install -y --setopt=install_weak_deps=0 gcc-toolset-14 zlib-devel xz-devel make && \
    microdnf clean all && \
    rm -rf /var/cache/yum /var/lib/yum
RUN --mount=type=cache,from=epel-base,source=/zeromq,target=/zeromq \
    --mount=type=cache,from=epel-base,source=/libsodium,target=/libsodium \
    --mount=type=cache,from=epel-base,source=/libunwind,target=/libunwind \
    --mount=type=cache,from=epel-base,source=/libpgm,target=/libpgm \
    source /opt/rh/gcc-toolset-14/enable && \
    make -C /zeromq install && \
    make -C /libsodium install && \
    make -C /libunwind install && \
    make -C /libpgm/openpgm/pgm install

COPY --from=go-builder /workspace/bin/epp /app/epp

USER 65532:65532

# expose gRPC, health and metrics ports
EXPOSE 9002
EXPOSE 9003
EXPOSE 9090
# expose port for KV-Events ZMQ SUB socket
EXPOSE 5557

ENTRYPOINT ["/app/epp"]


LABEL com.redhat.component="odh-llm-d-inference-scheduler" \
      name="odh-llm-d-inference-scheduler" \
      description="odh-llm-d-inference-scheduler" \
      summary="odh-llm-d-inference-scheduler" \
      io.k8s.display-name="odh-llm-d-inference-scheduler" \
      io.k8s.description="odh-llm-d-inference-scheduler"
